[{"id": "cul01", "title": "豫章故郡，洪都新府", "era": "汉代", "year": "公元前202年", "description": "汉高祖六年（公元前202年），刘邦置豫章郡，设南昌县，南昌建城史由此开启。\"物华天宝，龙光射牛斗之墟；人杰地灵，徐孺下陈蕃之榻\"，王勃笔下的南昌早已名扬天下。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Ancient%20Nanchang%20city%20gate%20tower%20in%20Han%20dynasty%20style%2C%20traditional%20Chinese%20fortified%20city%20entrance%2C%20historical%20illustration%20with%20warm%20tones&image_size=landscape_16_9", "type": "历史沿革"}, {"id": "cul02", "title": "白鹿洞书院", "era": "唐代", "year": "公元789年", "description": "位于庐山五老峰下的白鹿洞书院，始建于唐贞元年间，为中国古代四大书院之首。朱熹在此讲学并制定《白鹿洞书院揭示》，成为中国教育史上最重要的学规之一。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=White%20Deer%20Grotto%20Academy%20traditional%20Chinese%20scholar%20academy%20in%20mountains%2C%20wooden%20buildings%20with%20tiled%20roofs%2C%20peaceful%20study%20environment%20with%20bamboo&image_size=landscape_16_9", "type": "书院文化"}, {"id": "cul03", "title": "宋代瓷业巅峰", " era": "宋代", "year": "公元1004年", "description": "宋真宗景德元年，昌南镇因所产青白瓷品质卓越而被赐名\"景德镇\"。宋代景德镇瓷器已远销海外，海上丝绸之路上的中国瓷器多产于此，景德镇从此走向世界。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Song%20dynasty%20porcelain%20kiln%20firing%20scene%2C%20craftsmen%20making%20blue%20and%20white%20ceramics%2C%20ancient%20Chinese%20pottery%20workshop%20with%20flames%20and%20smoke&image_size=landscape_16_9", "type": "陶瓷文化"}, {"id": "cul04", "title": "欧阳修与曾巩", "era": "宋代", "year": "公元11世纪", "description": "江西吉安人欧阳修与南丰人曾巩位列\"唐宋八大家\"，两人均为北宋文坛领袖。欧阳修领导了诗文革新运动，曾巩以散文见长，江西文风之盛可见一斑。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Song%20dynasty%20scholar%20writing%20calligraphy%20by%20candlelight%2C%20traditional%20Chinese%20study%20room%20with%20scrolls%20and%20brushes%2C%20ink%20stone%20and%20paper&image_size=landscape_16_9", "type": "文人墨客"}, {"id": "cul05", "title": "明代戏曲大家汤显祖", "era": "明代", "year": "公元1550年", "description": "临川（今抚州）人汤显祖被誉为\"东方莎士比亚\"，其代表作《牡丹亭》《邯郸记》《南柯记》《紫钗记》合称\"临川四梦\"，是中国戏曲史上的巅峰之作。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Ming%20dynasty%20opera%20performance%20stage%20with%20traditional%20costumes%2C%20Chinese%20theater%20with%20elaborate%20sets%20and%20makeup%2C%20Tang%20Xianzu%20Peony%20Pavilion%20theme&image_size=landscape_16_9", "type": "戏曲艺术"}, {"id": "cul06", "title": "井冈星火", "era": "近代", "year": "公元1927年", "description": "1927年10月，毛泽东率领秋收起义部队到达井冈山，创建了中国第一个农村革命根据地。星星之火，从这里开始燎原，江西成为中国革命的重要摇篮。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Red%20army%20soldiers%20marching%20on%20Jinggangshan%20mountain%20trail%2C%20Chinese%20revolutionary%20history%2C%20red%20flags%20waving%20amidst%20green%20forests%2C%20monumental%20atmosphere&image_size=landscape_16_9", "type": "红色文化"}, {"id": "cul07", "title": "南昌起义", "era": "近代", "year": "公元1927年", "description": "1927年8月1日，周恩来、贺龙、叶挺、朱德、刘伯承等在南昌发动武装起义，打响了武装反抗国民党反动派的第一枪。这一天后来成为中国人民解放军建军节。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Nanchang%20Uprising%20memorial%20hall%20with%20red%20star%20emblem%2C%20revolutionary%20monument%20architecture%2C%20August%201%20military%20history%20commemoration&image_size=landscape_16_9", "type": "红色文化"}, {"id": "cul08", "title": "赣傩文化", "era": "远古流传", "year": "3000年前", "description": "赣傩是江西古老的民间舞蹈艺术，被称为\"中国古代活化石\"。南丰石邮傩舞最为著名，面具造型古朴夸张，舞步刚劲有力，寄托着驱邪纳福的美好愿望。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Gan%20Nuo%20dance%20performers%20wearing%20traditional%20wooden%20masks%2C%20ancient%20Chinese%20exorcism%20ritual%20dance%2C%20colorful%20ceremonial%20masks%20and%20costumes&image_size=landscape_16_9", "type": "非遗传承"}]