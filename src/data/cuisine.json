[{"id": "c01", "name": "南昌瓦罐汤", "category": "传统小吃", "origin": "南昌市", "description": "以土质瓦罐为容器，文火慢煨七小时以上，汤汁浓郁醇厚，肉质酥烂入味。配上一根南昌炒粉，便是地道的南昌早餐。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Nanchang%20clay%20pot%20soup%20with%20meat%20and%20herbs%2C%20steaming%20hot%20traditional%20Chinese%20soup%20in%20earthenware%20jar%2C%20rich%20broth%2C%20appetizing%20food%20photography&image_size=square", "taste": "鲜香浓郁，入口即化"}, {"id": "c02", "name": "江西米粉", "category": "传统主食", "origin": "全省各地", "description": "江西人的一天从一碗粉开始。无论是南昌拌粉、抚州泡粉还是景德镇冷粉，每地都有独特的风味。米香四溢，劲道爽滑。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Jiangxi%20rice%20noodles%20with%20spicy%20sauce%20and%20toppings%2C%20Chinese%20rice%20vermicelli%20dish%2C%20glistening%20noodles%20with%20chopped%20green%20onions%20and%20chili%20oil&image_size=square", "taste": "爽滑筋道，辣而不燥"}, {"id": "c03", "name": "藜蒿炒腊肉", "category": "赣菜经典", "origin": "南昌市", "description": "\"鄱阳湖的草，南昌人的宝\"。藜蒿清香脆嫩，腊肉咸香下饭，两者搭配堪称绝妙。这道菜被列为\"赣菜十大名菜\"之一。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Stir-fried%20Artemisia%20selengensis%20with%20cured%20pork%20belly%2C%20classic%20Gan%20cuisine%20dish%2C%20vibrant%20green%20vegetables%20with%20savory%20meat%2C%20wok%20heirloom&image_size=square", "taste": "清香脆嫩，咸鲜适口"}, {"id": "c04", "name": "莲花血鸭", "category": "赣菜经典", "origin": "萍乡市", "description": "萍乡莲花县的特色名菜，选用当地散养麻鸭，配以新鲜鸭血爆炒而成。色泽紫红鲜亮，鸭肉嫩滑鲜美，是萍乡宴席上的头道大菜。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Lianhua%20blood%20duck%20stir-fry%2C%20traditional%20Jiangxi%20dish%20with%20dark%20red%20sauce%2C%20diced%20duck%20meat%20with%20chili%20peppers%2C%20authentic%20Chinese%20cuisine&image_size=square", "taste": "鲜嫩辛辣，回味无穷"}, {"id": "c05", "name": "宁都三杯鸡", "category": "赣菜经典", "origin": "赣州市", "description": "因烹制时不放水，仅用一杯米酒、一杯猪油、一杯酱油而得名。鸡肉色泽红润，原汁原味，醇香扑鼻，是赣南客家菜的代表作。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Three-cup%20chicken%20Sanbei%20ji%2C%20Hakka%20cuisine%20from%20southern%20Jiangxi%2C%20glossy%20dark%20soy%20sauce%20glazed%20chicken%20pieces%2C%20sesame%20seeds%20garnish&image_size=square", "taste": "酱香浓郁，软烂脱骨"}, {"id": "c06", "name": "九江茶饼", "category": "特色糕点", "origin": "九江市", "description": "九江传统名点，外皮酥脆，内馅香甜，以桂花、芝麻、椒盐等多种口味著称。配上一壶庐山云雾茶，便是完美的下午茶时光。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Jiujiang%20tea%20cakes%20traditional%20pastries%2C%20round%20flaky%20Chinese%20pastry%20with%20sweet%20filling%2C%20sesame%20seeds%20on%20top%2C%20arranged%20elegantly%20on%20plate&image_size=square", "taste": "酥脆香甜，茶香悠长"}, {"id": "c07", "name": "瑞金牛肉汤", "category": "地方特色", "origin": "瑞金市", "description": "瑞金人的早餐灵魂，选用新鲜牛肉切薄片，加入红薯粉丝和特制调料煮成。汤鲜肉嫩，一碗下肚暖胃又暖心。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Ruijin%20beef%20soup%20with%20thinly%20sliced%20fresh%20beef%20and%20glass%20noodles%2C%20clear%20broth%20with%20green%20onions%2C%20comforting%20Chinese%20breakfast%20soup&image_size=square", "taste": "汤鲜肉嫩，清淡鲜美"}, {"id": "c08", "name": "抚州泡粉", "category": "传统主食", "origin": "抚州市", "description": "抚州最具代表性的美食，以粗圆米粉为主料，经久泡不烂。配上牛肉或猪杂臊子，浇上秘制汤底，嗦一口便知人间值得。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Fuzhou%20soaked%20rice%20noodles%20thick%20round%20vermicelli%20in%20rich%20broth%2C%20Jiangxi%20style%20noodle%20soup%20with%20beef%20topping%2C%20steaming%20bowl&image_size=square", "taste": "柔韧弹牙，汤浓味美"}, {"id": "c09", "name": "铅山烫粉", "category": "传统主食", "origin": "上饶市", "description": "上饶铅山的特色小吃，米粉在滚水中快速烫熟后捞出，淋上由辣椒、蒜蓉、酱油调制的酱汁，简单却滋味无穷。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Yanshan%20scalded%20rice%20noodles%20with%20spicy%20garlic%20sauce%2C%20Jiangxi%20street%20food%2C%20white%20noodles%20with%20red%20chili%20oil%20and%20minced%20garlic%20topping&image_size=square", "taste": "麻辣鲜香，开胃爽口"}, {"id": "c10", "name": "丰城冻米糖", "category": "特色糕点", "origin": "宜春市", "description": "江西传统年货代表，以糯米熬制的糖稀粘合爆米花制成。洁白晶莹，松脆香甜，承载着无数江西人的童年记忆。", "image": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Fengcheng%20frozen%20rice%20candy%20traditional%20Chinese%20sweet%2C%20crispy%20puffed%20rice%20treats%20bound%20with%20sugar%20syrup%2C%20white%20and%20crunchy%20square%20pieces&image_size=square", "taste": "松脆甜美，米香浓郁"}]